# ElevenLabs API key used for cloned JARVIS actor voice rendering.
ELEVENLABS_API_KEY=

# Optional OpenAI key if OpenClaw fallback/OpenAI providers are enabled.
OPENAI_API_KEY=

# Optional Merriam-Webster Collegiate API key for pronunciation normalization.
JARVIS_MERRIAM_API_KEY=

# Optional local Whisper model path used by OpenClaw media transcription.
WHISPER_CPP_MODEL=

# Cognition defaults (auto-select now prefers stronger local dialogue models like qwen3:14b).
JARVIS_COGNITION_BACKEND=ollama
JARVIS_COGNITION_MODEL=qwen3:14b
JARVIS_COGNITION_AUTO_PREFER=qwen3:14b,qwen3:30b,gemma3:27b,qwen3:8b,llama3.2:3b-instruct,llama3.2:3b,qwen2.5:3b-instruct,qwen2.5:3b,mistral:7b-instruct
JARVIS_PRESENCE_MODEL_FIRST=true

# Optional dialogue retrieval rerank toggles.
JARVIS_DIALOGUE_EMBED_RERANK_ENABLED=true
JARVIS_DIALOGUE_EMBED_MODEL=mxbai-embed-large
JARVIS_DIALOGUE_FLAG_RERANK_ENABLED=true
JARVIS_DIALOGUE_FLAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Optional low-power serving profile toggle.
JARVIS_LOW_POWER_MODE=false
JARVIS_PARTNER_DIALOGUE_TIMEOUT_SECONDS=10
JARVIS_PARTNER_DEEP_TIMEOUT_SECONDS=12
JARVIS_PARTNER_RETRIEVAL_TARGET_SNIPPETS=4
JARVIS_PARTNER_DEEP_RETRIEVAL_TARGET_SNIPPETS=4
JARVIS_PRESENCE_MODEL_TIMEOUT_SECONDS=20
